    function loadImages() {
      for (let i = 1; i <= totalImages; i++) {
        const imageItem = document.createElement("div");
        imageItem.className = "image-item";

        const img = document.createElement("img");
        img.src = `${baseUrl}/imagen_${i}.jpg`;
        img.alt = `Imagen ${i}`;
        img.loading = "lazy";

        img.onerror = function () {
          imageItem.remove();
        };

        imageItem.appendChild(img);
        imageContainer.appendChild(imageItem);
      }

      const note = document.createElement("div");
      note.className = "footer-note";
      note.textContent = "seguir bajando también es una forma de pensar";
      imageContainer.appendChild(note);
    }

    function createFloatingTexts() {
      for (let i = 0; i < 18; i++) {
        const el = document.createElement("div");
        el.className = "floating-text";
        el.textContent = frases[i % frases.length];

        el.style.top = `${Math.random() * 90}%`;
        el.style.left = `${Math.random() * 20 - 20}%`;
        el.style.animationDuration = `${18 + Math.random() * 20}s`;
        el.style.animationDelay = `${Math.random() * 12}s`;
        el.style.fontSize = `${14 + Math.random() * 14}px`;

        floatingTexts.appendChild(el);
      }
    }

    function createGhostImages() {
      for (let i = 1; i <= 10; i++) {
        const ghost = document.createElement("img");
        const n = 1 + Math.floor(Math.random() * totalImages);

        ghost.src = `${baseUrl}/imagen_${n}.jpg`;
        ghost.className = "ghost-img";
        ghost.alt = "fantasma visual";

        ghost.style.left = `${Math.random() * 100}%`;
        ghost.style.animationDuration = `${20 + Math.random() * 20}s`;
        ghost.style.animationDelay = `${Math.random() * 15}s`;
        ghost.style.width = `${80 + Math.random() * 120}px`;

        ghost.onerror = function () {
          ghost.remove();
        };

        ghostLayer.appendChild(ghost);
      }
    }

    loadImages();
    createFloatingTexts();
    createGhostImages();
